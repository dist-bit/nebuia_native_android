<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:theme="@style/ThemeOverlay.NebuIA.FullscreenContainer"
    tools:context=".activities.face.liveness.FaceLivenessActivity">

    <!-- Camera preview (front-facing) -->
    <com.otaliastudios.cameraview.CameraView
        android:id="@+id/camera"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        app:cameraEngine="camera2"
        app:cameraFacing="front"
        app:cameraFlash="off"
        app:cameraMode="picture"
        app:cameraPlaySounds="false"
        app:cameraPreview="glSurface"
        app:cameraRequestPermissions="true"
        app:cameraUseDeviceOrientation="true"
        app:cameraWhiteBalance="auto" />

    <!-- Oval overlay with progress arc -->
    <com.distbit.nebuia_plugin.utils.views.FaceOvalOverlayView
        android:id="@+id/ovalOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar: back button + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="@dimen/_28sdp">

        <Button
            android:id="@+id/back"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="@dimen/_32sdp"
            android:layout_height="@dimen/_32sdp"
            android:layout_marginStart="@dimen/_10sdp"
            android:drawableStart="@drawable/baseline_arrow_back_ios_24"
            android:drawablePadding="0dp"
            tools:ignore="RtlSymmetry" />

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_marginEnd="@dimen/_42sdp"
            android:text="@string/liveness_title"
            android:textColor="@android:color/white"
            android:textSize="@dimen/_16ssp" />
    </LinearLayout>

    <!-- Guidance pill - INSIDE the oval area, centered -->
    <TextView
        android:id="@+id/guidanceMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/_200sdp"
        android:background="@drawable/guidance_pill_bg"
        android:elevation="4dp"
        android:gravity="center"
        android:paddingStart="@dimen/_16sdp"
        android:paddingTop="@dimen/_6sdp"
        android:paddingEnd="@dimen/_16sdp"
        android:paddingBottom="@dimen/_6sdp"
        android:text="@string/liveness_position_face"
        android:textAlignment="center"
        android:textColor="#DD000000"
        android:textSize="@dimen/_11ssp"
        android:textStyle="bold" />

    <!-- Loader (shown during analysis) -->
    <ProgressBar
        android:id="@+id/loader"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:indeterminateTint="@android:color/white"
        android:indeterminateTintMode="src_atop"
        android:maxWidth="@dimen/_28sdp"
        android:maxHeight="@dimen/_28sdp"
        android:minWidth="@dimen/_28sdp"
        android:minHeight="@dimen/_28sdp"
        android:visibility="gone" />

    <!-- Status label (shown during analysis) -->
    <TextView
        android:id="@+id/statusLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_40sdp"
        android:layout_marginEnd="@dimen/_15sdp"
        android:gravity="center"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="@dimen/_12ssp"
        android:visibility="gone" />

    <!-- Bottom: NebuIA branding -->
    <ImageView
        android:id="@+id/bottomPanel"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/_20sdp"
        android:contentDescription="@string/powered_by_nebuia"
        android:src="@drawable/nebuia_white" />

    <!-- Result overlay (success / error) -->
    <FrameLayout
        android:id="@+id/resultOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <!-- Success -->
        <LinearLayout
            android:id="@+id/successLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/_20sdp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="@color/liveness_green"
                android:textSize="@dimen/_48ssp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="@string/liveness_success"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_16ssp" />
        </LinearLayout>

        <!-- Error -->
        <LinearLayout
            android:id="@+id/errorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/_20sdp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/liveness_red"
                android:textSize="@dimen/_48ssp" />

            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:gravity="center"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_14ssp" />

            <Button
                android:id="@+id/retryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_15sdp"
                android:paddingStart="@dimen/_20sdp"
                android:paddingEnd="@dimen/_20sdp"
                android:text="@string/liveness_retry"
                android:textAllCaps="false" />
        </LinearLayout>

    </FrameLayout>

</FrameLayout>
